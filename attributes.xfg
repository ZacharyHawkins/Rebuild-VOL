<?xml version="1.0"?>

<!--      all properties that are in the given class.
	state - specifies that the entry is a lock/unlock/hidden entry.
              valid default values are "locked", "unlocked" or "hidden" 
			  where hidden implies locked
	value - specifies the default value assigned to the entry - not
              valid when used in conjunction with state

	All entries default to the following values.
		a value of 0 with a class of 0

	Current Classes
		0 = default - just a value.
		1 = monster lock/unlock
		2 = city lock/unlock
		3 = atari powerups
		4 = gallery item lock/unlock
		5 = challenge lock/unlock
		6 = Final Wars item lock/unlock
		7 = monster packages
		8 = city packages
-->

